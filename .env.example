# ─────────────────────────────────────────────────────────────
#  Zyeeque - Environment Variables
#  Salin file ini menjadi .env.local lalu isi nilainya.
#  JANGAN commit .env.local ke Git!
# ─────────────────────────────────────────────────────────────

# ── Auth ──────────────────────────────────────────────────────
# Username untuk login ke dashboard
AUTH_USERNAME=admin

# Password untuk login ke dashboard
AUTH_PASSWORD=ganti_dengan_password_kuat

# Secret key untuk cookie session — isi dengan string acak yang panjang.
# Generate contoh: openssl rand -base64 32
AUTH_SECRET=ganti_dengan_random_string_panjang_minimal_32_karakter

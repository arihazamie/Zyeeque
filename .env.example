# ─────────────────────────────────────────────────────────────
#  Zyeeque - Environment Variables
#  Salin file ini menjadi .env.local lalu isi nilainya.
#  JANGAN commit .env.local ke Git!
# ─────────────────────────────────────────────────────────────

# ── Auth ──────────────────────────────────────────────────────
AUTH_USERNAME=admin
AUTH_PASSWORD=ganti_dengan_password_kuat
AUTH_SECRET=ganti_dengan_random_string_panjang_minimal_32_karakter

# ── OpenRouter AI ─────────────────────────────────────────────
# Dapatkan API key di: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxx

# Model default (opsional — default: anthropic/claude-3.5-haiku)
# Pilihan populer untuk scalping (cepat + murah):
#   anthropic/claude-3.5-haiku       ← recommended
#   google/gemini-flash-1.5
#   meta-llama/llama-3.1-8b-instruct:free
#   deepseek/deepseek-r1:free
OPENROUTER_MODEL=anthropic/claude-3.5-haiku

# URL site kamu (untuk HTTP-Referer header OpenRouter)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
